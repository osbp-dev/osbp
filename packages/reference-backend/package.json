{
  "name": "@osbp/reference-backend",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@osbp/core": "0.1.0"
  },
  "scripts": {
    "build": "tsc -b",
    "check": "tsc -b --pretty false",
    "clean": "tsc -b --clean",
    "demo": "npm run build --silent && node dist/cli.js --demo",
    "smoke": "node dist/cli.js --smoke",
    "test": "node --test dist/*.test.js"
  }
}
