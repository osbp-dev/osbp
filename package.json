{
  "name": "open-service-booking-protocol",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/osbp-core packages/reference-backend packages/osbp-conformance packages/adapter-starter",
    "build:spec": "node scripts/build-spec.mjs",
    "check": "npm run build && npm run check:spec && npm run check:adapter-context",
    "check:spec": "node scripts/build-spec.mjs --check",
    "check:adapter-context": "node scripts/build-adapter-context.mjs --check",
    "spell": "cspell \"**/*.{md,ts,mts,mjs,json,txt,yml,yaml}\" --no-progress",
    "clean": "tsc -b packages/osbp-core packages/reference-backend packages/osbp-conformance packages/adapter-starter --clean",
    "test": "node --test scripts/*.test.mjs packages/*/dist/*.test.js",
    "trace": "npm run build --silent && node scripts/run-reference-trace.mjs",
    "conformance": "npm run build --silent && node packages/osbp-conformance/dist/cli.js",
    "coverage": "npm run build && node --test --experimental-test-coverage --test-coverage-include='packages/*/dist/*.js' --test-coverage-exclude='packages/*/dist/*.test.js' packages/*/dist/*.test.js",
    "demo": "npm run demo --workspace @osbp/reference-backend"
  },
  "devDependencies": {
    "@types/node": "^24.13.0",
    "cspell": "^10.0.1",
    "typescript": "^6.0.3"
  },
  "homepage": "https://osbp.dev"
}
